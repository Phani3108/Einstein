# ──────────────────────────────────────────────────
# Einstein Configuration
# ──────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
# Local (SQLite — zero config):
# DATABASE_URL=sqlite+aiosqlite:///einstein.db
# Cloud (PostgreSQL):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/personal_semantic_engine

TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/test_semantic_engine

# ── API ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Security ──────────────────────────────────────
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── LLM Configuration ────────────────────────────
# Local (Ollama):
# LLM_MODEL=ollama/llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# Cloud (OpenAI/Anthropic/DeepSeek):
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── Embedding Provider ────────────────────────────
# Local (Ollama):
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# Cloud (OpenAI):
OPENAI_API_KEY=your-openai-api-key-here

# ── Cloud API Keys (only for cloud mode) ──────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Vector Database (optional, cloud only) ────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=your-pinecone-environment-here

# ── Redis (optional, for background workers) ──────
# REDIS_URL=redis://localhost:6379
